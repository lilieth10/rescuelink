# RescueLink API — Environment Variables

# Server
PORT=3001
NODE_ENV=development

# Database (Docker Compose)
DATABASE_URL="postgresql://rescuelink:rescuelink_dev@localhost:5432/rescuelink?schema=public"

# Redis (Docker Compose)
REDIS_URL="redis://localhost:6379"

# JWT
JWT_SECRET="change-me-in-production-use-long-random-string"
JWT_EXPIRES_IN="7d"

# CORS
CORS_ORIGIN="http://localhost:3000"

# Seed (solo desarrollo — cambiar en producción)
SEED_ADMIN_EMAIL="admin@rescuelink.org"
SEED_ADMIN_PASSWORD="RescueLink2026!"
